<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.katsulabs.bi.infrastructure.domains.category.persistence.mybatis.CategoryMapper">

    <select id="findAll" resultType="com.katsulabs.bi.infrastructure.domains.category.persistence.mybatis.CategoryRow">
        SELECT category_id AS id,
               name,
               owner_user_id AS userId
          FROM ib_category
         ORDER BY name
    </select>

    <select id="findById" resultType="com.katsulabs.bi.infrastructure.domains.category.persistence.mybatis.CategoryRow">
        SELECT category_id AS id,
               name,
               owner_user_id AS userId
          FROM ib_category
         WHERE category_id = #{id}
    </select>

    <select id="countByName" resultType="int">
        SELECT COUNT(1) FROM ib_category
         WHERE name = #{name}
        <if test="excludeId != null">
           AND category_id &lt;&gt; #{excludeId}
        </if>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="category_id">
        INSERT INTO ib_category (name, owner_user_id)
        VALUES (#{name}, #{userId})
    </insert>

    <update id="update">
        UPDATE ib_category SET name = #{name} WHERE category_id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM ib_category WHERE category_id = #{id}
    </delete>
</mapper>
